# MongoDB connection.
# REQUIRED: MongoDB 4.2+ running as a replica set (MongoDB Atlas, or a local
# single-node replica set). MongoDB 4.0.x is NOT supported - Prisma sends
# updates as aggregation pipelines and 4.0.x rejects them with a TypeMismatch
# on 'update.updates.u'. `npm run db:check` verifies this before dev/seed.
# Atlas example: mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/portal_media?retryWrites=true&w=majority
DATABASE_URL="mongodb://127.0.0.1:27017/portal_media?replicaSet=rs0"

# Redis (optional in dev — app degrades to an in-memory fallback if unreachable)
REDIS_URL="redis://127.0.0.1:6379"

# Session secret used to sign cookies
SESSION_SECRET="change-me-in-production-please-use-a-long-random-string"

# Public site URL (used for sitemap / canonical)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Seed credentials (DEV ONLY — rotate/disable before production) ----
SEED_SUPERADMIN_EMAIL="superadmin@portal.test"
SEED_SUPERADMIN_PASSWORD="superadmin123"
SEED_ADMIN_EMAIL="admin@portal.test"
SEED_ADMIN_PASSWORD="admin123"
SEED_PUBLISHER_EMAIL="publisher@portal.test"
SEED_PUBLISHER_PASSWORD="publisher123"
SEED_SEO_EMAIL="seo@portal.test"
SEED_SEO_PASSWORD="seo123"
SEED_USER_EMAIL="reader@portal.test"
SEED_USER_PASSWORD="reader123"
