# Prisma's MongoDB connector requires a REPLICA SET on MongoDB 4.2+.
# This points at the Docker container `mongodb` (mongo:8.2, single-node replica set
# rs0, auth admin/secret). Verified by `npm run db:check`.
DATABASE_URL="mongodb://admin:secret@127.0.0.1:27017/portal_media?replicaSet=rs0&authSource=admin"
REDIS_URL="redis://127.0.0.1:6379"
SESSION_SECRET="dev-secret-change-me-0123456789abcdef0123456789abcdef"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SEED_SUPERADMIN_EMAIL="superadmin@portal.test"
SEED_SUPERADMIN_PASSWORD="superadmin123"
SEED_ADMIN_EMAIL="admin@portal.test"
SEED_ADMIN_PASSWORD="admin123"
SEED_PUBLISHER_EMAIL="publisher@portal.test"
SEED_PUBLISHER_PASSWORD="publisher123"
SEED_SEO_EMAIL="seo@portal.test"
SEED_SEO_PASSWORD="seo123"
SEED_USER_EMAIL="reader@portal.test"
SEED_USER_PASSWORD="reader123"
